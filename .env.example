# Firebase web config for agencyx.
# These are NOT secrets — Firebase web keys are safe to expose in client builds;
# access is controlled by enabled Auth providers + Authorized domains, not the key.
# src/auth/firebase.js already falls back to the agencyx-8c5b0 values, so setting
# these is optional. Define them (e.g. in Vercel project settings) to point a build
# at a different Firebase project/environment.

VITE_FIREBASE_API_KEY=AIzaSyAhxJyi0t7f_qM4MQ7EhKxoYDy-zSgg9uU
VITE_FIREBASE_AUTH_DOMAIN=agencyx-8c5b0.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=agencyx-8c5b0
VITE_FIREBASE_STORAGE_BUCKET=agencyx-8c5b0.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=267324385662
VITE_FIREBASE_APP_ID=1:267324385662:web:9dcceea49f6f16ec29ab2f
VITE_FIREBASE_MEASUREMENT_ID=G-9C3NS0BTGE
